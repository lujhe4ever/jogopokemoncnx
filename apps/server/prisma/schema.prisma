generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RuntimeMarker {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}

model Account {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  profile      Profile?
  sessions     Session[]
  tickets      WebSocketTicket[]
  checkpoint   PlayerCheckpoint?
  inventory    InventoryStack[]
  claims       InteractionClaim[]
  creatures    Creature[]
  progression  CreatureProgressionEvent[]
  battles      BattleRecord[]
  encounters   EncounterRecord[]
}

model BattleRecord {
  id               String    @id
  seed             Int
  outcome          String?
  winner           String?
  experienceReward Int       @default(0)
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  ownerId          String
  owner            Account   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  encounter        EncounterRecord?

  @@index([ownerId])
}

model EncounterRecord {
  id                 String    @id
  zoneId             String
  definitionId       String
  definitionVersion  Int
  catalogVersion     Int
  seed               Int
  status             String    @default("battling")
  captureRequestId   String?
  captureSucceeded   Boolean?
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
  ownerId            String
  battleId           String    @unique
  capturedCreatureId String?   @unique
  owner              Account   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  battle             BattleRecord @relation(fields: [battleId], references: [id], onDelete: Cascade)
  capturedCreature   Creature? @relation("CapturedCreature", fields: [capturedCreatureId], references: [id], onDelete: SetNull)

  @@unique([ownerId, captureRequestId])
  @@index([ownerId, status])
}

model Creature {
  id                String   @id @default(cuid())
  definitionId      String
  definitionVersion Int
  catalogVersion    Int
  experience        Int      @default(0)
  level             Int      @default(1)
  teamSlot          Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  ownerId           String
  owner             Account  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  progression       CreatureProgressionEvent[]
  capturedFrom      EncounterRecord? @relation("CapturedCreature")

  @@unique([ownerId, teamSlot])
  @@index([ownerId])
}

model CreatureProgressionEvent {
  id         String   @id @default(cuid())
  requestId  String
  amount     Int
  createdAt  DateTime @default(now())
  ownerId    String
  creatureId String
  owner      Account  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  creature   Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  @@unique([ownerId, requestId])
  @@index([creatureId])
}

model InventoryStack {
  id        String   @id @default(cuid())
  itemId    String
  quantity  Int
  updatedAt DateTime @updatedAt
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, itemId])
  @@index([accountId])
}

model InteractionClaim {
  id            String   @id @default(cuid())
  interactionId String
  claimedAt     DateTime @default(now())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, interactionId])
  @@index([accountId])
}

model PlayerCheckpoint {
  id        String   @id @default(cuid())
  x         Float
  y         Float
  zoneId    String   @default("house")
  updatedAt DateTime @updatedAt
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Profile {
  id          String  @id @default(cuid())
  displayName String
  accountId   String  @unique
  account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Session {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model WebSocketTicket {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model AuthAudit {
  id        String   @id @default(cuid())
  event     String
  success   Boolean
  ipHash    String?
  createdAt DateTime @default(now())
}
