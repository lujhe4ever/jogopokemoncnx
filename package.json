{
  "name": "projeto-lt",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.14.0",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --parallel --filter @lt/server --filter @lt/web dev",
    "content:pokemon": "node scripts/generate-pokemon-canonical.mjs",
    "content:pokemon:audit": "node scripts/audit-pokemon-canonical-assets.mjs",
    "content:pokemon:assets-audit": "node scripts/generate-pokemon-assets-audit.mjs",
    "content:assets:generate": "node --experimental-strip-types scripts/generate-runtime-asset-catalogs.mjs",
    "content:assets:audit": "node --experimental-strip-types scripts/check-asset-catalogs.mjs --scope=assets",
    "content:audio:audit": "node --experimental-strip-types scripts/check-asset-catalogs.mjs --scope=audio",
    "content:animations:audit": "node --experimental-strip-types scripts/check-asset-catalogs.mjs --scope=animations",
    "assets:import": "node scripts/import-production-assets.mjs",
    "assets:inventory": "node scripts/generate-asset-deliverables.mjs",
    "assets:validate": "node --experimental-strip-types scripts/check-asset-catalogs.mjs --scope=all",
    "assets:coverage": "node scripts/generate-asset-deliverables.mjs",
    "assets:audit": "pnpm assets:validate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "build": "tsc -b && pnpm --filter @lt/web build && pnpm --filter @lt/admin build",
    "security:secrets": "node scripts/check-secrets.mjs",
    "security:licenses": "node scripts/check-content-licenses.mjs",
    "security:runtime-content": "node scripts/check-runtime-content-boundaries.mjs",
    "alpha:readiness": "node scripts/check-alpha-readiness.mjs",
    "budget": "node scripts/check-budgets.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm budget && pnpm security:secrets && pnpm security:licenses && pnpm security:runtime-content && pnpm content:pokemon:audit && pnpm assets:validate && pnpm alpha:readiness"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.10.1",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.2.0",
    "pngjs": "7.0.0",
    "prettier": "3.9.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,json,md,yml,yaml}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
