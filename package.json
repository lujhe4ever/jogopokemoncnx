{
  "name": "projeto-lt",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.14.0",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --parallel --filter @lt/server --filter @lt/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "build": "tsc -b && pnpm --filter @lt/web build && pnpm --filter @lt/admin build",
    "security:secrets": "node scripts/check-secrets.mjs",
    "security:licenses": "node scripts/check-content-licenses.mjs",
    "alpha:readiness": "node scripts/check-alpha-readiness.mjs",
    "budget": "node scripts/check-budgets.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm budget && pnpm security:secrets && pnpm security:licenses && pnpm alpha:readiness"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.10.1",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.2.0",
    "prettier": "3.9.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,json,md,yml,yaml}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
