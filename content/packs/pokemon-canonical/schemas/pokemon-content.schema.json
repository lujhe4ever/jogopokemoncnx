{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lujhe4ever/jogopokemoncnx/content/packs/pokemon-canonical/schemas/pokemon-content.schema.json",
  "title": "Pokemon canonical content schemas v2",
  "type": "object",
  "$defs": {
    "approvalStatus": {
      "type": "string",
      "enum": ["approved", "pending", "doubtful", "rejected", "quarantined"]
    },
    "sourceInfo": {
      "type": "object",
      "required": [
        "retrievedAt",
        "sourceRevision",
        "sourceUrls",
        "licenseStatus",
        "requiredCredits",
        "notes"
      ],
      "properties": {
        "retrievedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "sourceRevision": {
          "type": ["string", "null"]
        },
        "sourceUrls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "licenseStatus": {
          "$ref": "#/$defs/approvalStatus"
        },
        "requiredCredits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "pokemonSummary": {
      "type": "object",
      "required": [
        "id",
        "nationalDexNumber",
        "canonicalName",
        "slug",
        "path",
        "assetStatus",
        "definitionStatus",
        "licenseStatus",
        "spriteCandidates",
        "animationCandidates",
        "localQuarantineVerified"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^pokemon:\\d{4}-[a-z0-9-]+$"
        },
        "nationalDexNumber": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1025
        },
        "canonicalName": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "path": {
          "type": "string"
        },
        "assetStatus": {
          "$ref": "#/$defs/approvalStatus"
        },
        "definitionStatus": {
          "$ref": "#/$defs/approvalStatus"
        },
        "licenseStatus": {
          "$ref": "#/$defs/approvalStatus"
        },
        "spriteCandidates": {
          "type": "integer",
          "minimum": 0
        },
        "animationCandidates": {
          "type": "integer",
          "minimum": 0
        },
        "localQuarantineVerified": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "pokemonManifest": {
      "type": "object",
      "required": [
        "schemaVersion",
        "id",
        "nationalDexNumber",
        "canonicalName",
        "slug",
        "generationIntroduced",
        "types",
        "assetStatus",
        "definitionStatus",
        "licenseStatus",
        "sourceUrls",
        "requiredCredits",
        "notes"
      ],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "id": {
          "type": "string"
        },
        "nationalDexNumber": {
          "type": "integer",
          "minimum": 1
        },
        "canonicalName": {
          "type": "string"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "generationIntroduced": {
          "type": "integer",
          "minimum": 1
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "assetStatus": {
          "$ref": "#/$defs/approvalStatus"
        },
        "definitionStatus": {
          "$ref": "#/$defs/approvalStatus"
        },
        "licenseStatus": {
          "$ref": "#/$defs/approvalStatus"
        },
        "sourceUrls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "requiredCredits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "pokemonDefinition": {
      "type": "object",
      "required": [
        "schemaVersion",
        "id",
        "nationalDexNumber",
        "canonicalName",
        "slug",
        "generationIntroduced",
        "generationSource",
        "types",
        "physical",
        "baseStats",
        "biologyAndTraining",
        "abilities",
        "evolution",
        "source"
      ],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "id": {
          "type": "string"
        },
        "nationalDexNumber": {
          "type": "integer",
          "minimum": 1
        },
        "canonicalName": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "genus": {
          "type": ["string", "null"]
        },
        "generationIntroduced": {
          "type": "integer",
          "minimum": 1
        },
        "generationSource": {
          "type": "string"
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "physical": {
          "type": "object"
        },
        "baseExperience": {
          "type": ["integer", "null"]
        },
        "baseStats": {
          "type": "object"
        },
        "biologyAndTraining": {
          "type": "object"
        },
        "abilities": {
          "type": "array",
          "minItems": 1
        },
        "evolution": {
          "type": "object"
        },
        "source": {
          "$ref": "#/$defs/sourceInfo"
        }
      },
      "additionalProperties": false
    },
    "abilitiesDefinition": {
      "type": "object",
      "required": ["schemaVersion", "pokemonId", "abilities", "source"],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "pokemonId": {
          "type": "string"
        },
        "abilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "abilityId",
              "slot",
              "isHidden",
              "slug",
              "canonicalName",
              "shortEffect",
              "effect",
              "sourceUrl"
            ]
          }
        },
        "source": {
          "$ref": "#/$defs/sourceInfo"
        }
      },
      "additionalProperties": false
    },
    "movesDefinition": {
      "type": "object",
      "required": [
        "schemaVersion",
        "pokemonId",
        "format",
        "catalogs",
        "moves",
        "source"
      ],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "pokemonId": {
          "type": "string"
        },
        "format": {
          "type": "object"
        },
        "catalogs": {
          "type": "object",
          "required": ["moves", "moveMethods", "versionGroups"]
        },
        "moves": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moveTuple"
          }
        },
        "source": {
          "$ref": "#/$defs/sourceInfo"
        }
      },
      "additionalProperties": false
    },
    "moveTuple": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/learnMethodTuple"
          }
        }
      ]
    },
    "learnMethodTuple": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "prefixItems": [
        {
          "type": "integer"
        },
        {
          "type": "integer"
        },
        {
          "type": ["integer", "null"]
        },
        {
          "type": ["integer", "null"]
        },
        {
          "type": ["integer", "null"]
        },
        {
          "type": "array"
        }
      ]
    },
    "definitionValidationStatus": {
      "type": "object",
      "required": [
        "schemaVersion",
        "pokemonId",
        "status",
        "validatedAt",
        "validationLevel",
        "sourceRevision",
        "checks",
        "limitations"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "pokemonId": {
          "type": "string",
          "pattern": "^pokemon:\\d{4}-[a-z0-9-]+$"
        },
        "status": {
          "const": "approved"
        },
        "validatedAt": {
          "type": "string",
          "format": "date"
        },
        "validationLevel": {
          "const": "automated-schema-coverage-and-referential-integrity"
        },
        "sourceRevision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "checks": {
          "type": "object"
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "mediaInventory": {
      "type": "object",
      "required": [
        "schemaVersion",
        "pokemonId",
        "source",
        "mediaImportedCount",
        "statusSummary",
        "entries"
      ],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "pokemonId": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/sourceInfo"
        },
        "sourceUrlBase": {
          "type": "string",
          "format": "uri"
        },
        "rightsCatalogPath": {
          "type": "string"
        },
        "mediaImportedCount": {
          "type": "integer",
          "minimum": 0
        },
        "statusSummary": {
          "type": "object"
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "collection",
              "perspective",
              "variation",
              "animated",
              "extension",
              "sourceRepositoryPath",
              "rightsPolicyId",
              "status",
              "originalName",
              "proposedName"
            ]
          }
        }
      },
      "additionalProperties": false
    }
  }
}
